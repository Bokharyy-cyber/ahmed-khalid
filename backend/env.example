# ============================================================
# BOKHARY Portfolio API - Environment Configuration
# ✅ SECURE VERSION - DO NOT COMMIT .env TO GIT!
# ============================================================

# === ADMIN SECURITY ===
# ✅ CRITICAL: Generate a strong admin API key
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_API_KEY=your_super_secret_admin_key_here_CHANGE_ME

# === EMAIL CONFIGURATION ===
# ✅ DO NOT use your real Gmail password!
# Use Gmail App Password instead:
# 1. Go to myaccount.google.com/apppasswords
# 2. Select "Mail" and "Windows Computer"
# 3. Copy the 16-character password

GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ✅ Set your actual email (REQUIRED - no default!)
# This is where contact form submissions will be sent
OWNER_EMAIL=your_actual_email@gmail.com

# === DATABASE ===
# Local development (SQLite)
DATABASE_URL=sqlite:///./bokhary_messages.db

# Production (PostgreSQL on Render, Railway, etc.)
# DATABASE_URL=postgresql://user:password@hostname:5432/dbname

# === CORS & ORIGINS ===
# ✅ Set your actual domain(s)
# Separate multiple origins with commas
# Examples:
#   Local: http://localhost:8000,http://127.0.0.1:8000
#   Production: https://bokhary.com,https://www.bokhary.com
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# === ENVIRONMENT ===
# development | production
ENVIRONMENT=development

# ============================================================
# SECURITY CHECKLIST
# ============================================================
# ☑ ADMIN_API_KEY: Changed from default? Use secrets.token_urlsafe(32)
# ☑ GMAIL_APP_PASSWORD: Using App Password, not real password?
# ☑ OWNER_EMAIL: Set to YOUR actual email?
# ☑ DATABASE_URL: PostgreSQL for production?
# ☑ ALLOWED_ORIGINS: Set to YOUR domain?
# ☑ .env file: In .gitignore?
# ☑ Never commit .env to version control!
# ☑ Rotate admin key regularly
# ============================================================
